<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppDisertatieVacantaAI.Pages.InfoPage"
             Title="Despre aplicație"
             Shell.NavBarIsVisible="True"
             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkGray}}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Header -->
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="✈️" FontSize="48" HorizontalOptions="Center" />
                <Label Text="Planificator Vacanțe AI"
                       FontSize="24"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                <Label Text="Planifică-ți vacanța perfectă cu ajutorul inteligenței artificiale"
                       FontSize="14"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                       Opacity="0.8" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource MediumGray}}" />

            <!-- Ce poți face -->
            <VerticalStackLayout Spacing="16">
                <Label Text="Ce poți face în aplicație?"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />

                <!-- Item 1 -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="🏠" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Pagina principală"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                            <Label Text="Descoperă destinații recomandate, categorii populare și puncte de interes personalizate pentru tine."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Item 2 -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="🤖" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Chat cu AI"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                            <Label Text="Întreabă asistentul AI despre destinații, activități sau buget. Poate genera planificări complete pentru tine."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Item 3 -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="📋" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Planificări"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                            <Label Text="Creează sau vizualizează planificări de vacanță. Poți crea manual sau lăsa AI-ul să le genereze automat."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Item 4 -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="🔍" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Căutare"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                            <Label Text="Caută destinații după nume, țară sau buget. Filtrează și sortează rezultatele după preferințe."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Item 5 -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="❤️" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Favorite și recenzii"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                            <Label Text="Adaugă destinații la favorite și lasă recenzii. Recomandările se adaptează pe baza preferințelor tale."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Item 6 -->
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Label Text="🌤️" FontSize="24" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="Notificări meteo"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                            <Label Text="Primești notificări despre vremea din locația ta curentă, utile pentru planificarea zilei."
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource LightGray}, Dark={StaticResource MediumGray}}" />

            <!-- Licență -->
            <VerticalStackLayout Spacing="8">
                <Label Text="📄 Licență"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource DarkGray}, Dark={StaticResource LightGray}}" />
                <Frame BackgroundColor="{AppThemeBinding Light=#F8FCFF, Dark={StaticResource MediumGray}}"
                       CornerRadius="12" Padding="16" HasShadow="False">
                    <Label Text="MIT License&#x0a;&#x0a;Copyright (c) 2025 Dragos Chiper&#x0a;&#x0a;Permission is hereby granted, free of charge, to any person obtaining a copy of this software and associated documentation files (the &quot;Software&quot;), to deal in the Software without restriction, including without limitation the rights to use, copy, modify, merge, publish, distribute, sublicense, and/or sell copies of the Software, and to permit persons to whom the Software is furnished to do so, subject to the following conditions:&#x0a;&#x0a;The above copyright notice and this permission notice shall be included in all copies or substantial portions of the Software.&#x0a;&#x0a;THE SOFTWARE IS PROVIDED &quot;AS IS&quot;, WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE."
                           FontSize="11"
                           TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                           LineBreakMode="WordWrap" />
                </Frame>
            </VerticalStackLayout>

            <!-- Footer -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center" Margin="0,10,0,20">
                <Label x:Name="VersionLabel"
                       FontSize="12"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                       Opacity="0.6" />
                <Label Text="Dezvoltat ca proiect de disertație"
                       FontSize="12"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource MediumGray}, Dark={StaticResource LightGray}}"
                       Opacity="0.5" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
